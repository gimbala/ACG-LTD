# Copy to .env.local in this directory (ACG/) for local dev.
# In Vercel: Project Settings → Environment Variables (same names).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Booking emails use Supabase Edge Function + Resend (not VITE_*).
# Set these in Supabase Dashboard → Edge Functions → Secrets:
#   RESEND_API_KEY
#   RESEND_FROM_EMAIL      e.g. ACG Bookings <bookings@your-verified-domain.com>
#   BOOKING_NOTIFY_EMAIL   optional; defaults to hello@acghana.com
# Deploy: supabase functions deploy send-booking-confirmation (from repo root, CLI linked)
